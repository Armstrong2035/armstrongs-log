---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ScholarlyHeader from '../components/ScholarlyHeader.astro';

const allFreeNotes = await getCollection('freeNotes');

// Helper functions for series handling
const getSeriesName = (note) => {
    if (!note.data.series) return null;
    return typeof note.data.series === 'string' ? note.data.series : note.data.series.name;
};

const getSeriesOrder = (note) => {
    if (!note.data.series || typeof note.data.series === 'string') return Infinity;
    return note.data.series.order ?? Infinity;
};

// Group notes by series
const entriesBySeries = allFreeNotes.reduce((acc, note) => {
    const series = getSeriesName(note) || 'Uncollected';
    if (!acc[series]) acc[series] = [];
    acc[series].push(note);
    return acc;
}, {});

// Sort series items by their internal order, with date as a fallback
Object.keys(entriesBySeries).forEach(series => {
    entriesBySeries[series].sort((a, b) => {
        const orderA = getSeriesOrder(a);
        const orderB = getSeriesOrder(b);
        
        // If both have an order, sort by order (ascending)
        if (orderA !== Infinity || orderB !== Infinity) {
            return orderA - orderB;
        }
        
        // Fallback to date (descending)
        return b.data.date.valueOf() - a.data.date.valueOf();
    });
});

// Custom order for series display
const seriesOrder = [
    'Social Replacement Theory',
    'Signal & Sense',
    'Hacker Theology',
    'Culture And Humanness',
    'Meta Cognition',
    'Chess Theology'
];

const allProjectLogs = await getCollection('projectLogs');

// Group project logs by project name
const logsByProject = allProjectLogs.reduce((acc, log) => {
    const project = log.data.project || 'Miscellaneous';
    if (!acc[project]) acc[project] = [];
    acc[project].push(log);
    return acc;
}, {});

// Sort projects alphabetically (or could be custom)
const featuredProjects = Object.keys(logsByProject).sort();

// Sort logs within each project by date
Object.keys(logsByProject).forEach(project => {
    logsByProject[project].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
});

// Fetch Deep Dives
const allDeepDives = await getCollection('deepDives');
const deepDives = allDeepDives.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Sort and filter series using the previously defined seriesOrder
const featuredSeries = Object.keys(entriesBySeries)
    .filter(s => s !== 'Uncollected')
    .sort((a, b) => {
        const indexA = seriesOrder.indexOf(a);
        const indexB = seriesOrder.indexOf(b);
        if (indexA === -1 && indexB === -1) return a.localeCompare(b);
        if (indexA === -1) return 1;
        if (indexB === -1) return -1;
        return indexA - indexB;
    });
// Add Uncollected at the end if desired, but user just said "Series"
---

<Layout title="Armstrong's Log | Essays and projects">
  <div class="min-h-screen bg-zinc-950 text-zinc-300 selection:bg-blue-500/30 pb-20">
    
    <ScholarlyHeader />

    <main class="max-w-2xl mx-auto px-6">
        <!-- Narrative Intro -->
        <article class="prose prose-invert prose-zinc max-w-none">
            <p class="text-xl md:text-2xl text-white leading-relaxed mb-10 italic">
                Hi, I'm Armstrong.
            </p>
            
            <div class="text-zinc-400 space-y-6 text-lg leading-relaxed">
                <p>
                    I believe the internet is moving from the creator economy to the <span class="text-white font-bold">curator economy</span>. That the best digital products of the next decade will help users find and act on information specific to their context.
                </p>
                <p>
                    That the form this takes is <a href="/series/hacker-theology" class="link-scholarly text-white italic">AI co-pilots</a>. And that domain experts will make it happen by encoding their knowledge into products that drive <span class="italic font-bold text-white">niche results</span>.
                </p>
                <p>
                    That’s the future I’m betting the next decade of my life on. And I’m building software that accelerates it.
                </p>
            </div>
        </article>

        <div class="scholarly-hr"></div>

        <!-- Dynamic Project Index -->
        <div class="mb-20">
            <h2 class="text-[10px] font-sans font-bold uppercase tracking-[0.3em] text-zinc-600 mb-12 flex items-center gap-4">
                Active Projects <span class="h-px flex-1 bg-zinc-900"></span>
            </h2>
            
            <div class="grid grid-cols-1 gap-14">
                {featuredProjects.map(projectName => (
                    <section>
                        <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-500 mb-6 flex items-center gap-4">
                            {projectName} <span class="h-px flex-1 bg-zinc-900"></span>
                        </h3>
                        <ul class="space-y-6">
                            {logsByProject[projectName].map(log => (
                                <li class="flex items-start gap-4 group">
                                    <span class="text-emerald-500/50 mt-1.5 min-w-[12px]">⚒</span>
                                    <div class="flex-1">
                                        <a href={`/projectLogs/${log.slug}`} class="text-zinc-200 hover:text-emerald-400 border-b border-zinc-900 hover:border-emerald-900 transition-all text-xl leading-tight block pb-1">
                                            {log.data.title}
                                        </a>
                                        <div class="flex gap-3 text-xs font-mono text-zinc-600 mt-1.5 grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all">
                                            <span>{new Date(log.data.date).toLocaleDateString(undefined, { year: 'numeric', month: 'short' })}</span>
                                            {log.data.status && (
                                                <span class="uppercase tracking-tighter text-emerald-500/70 border border-emerald-900/30 px-1 rounded-sm text-[9px] font-bold">/ {log.data.status}</span>
                                            )}
                                        </div>
                                    </div>
                                </li>
                            ))}
                        </ul>
                    </section>
                ))}
            </div>
        </div>

        <div class="scholarly-hr"></div>

        <!-- Technical Deep Dives -->
        <div class="mb-20">
            <h2 class="text-[10px] font-sans font-bold uppercase tracking-[0.3em] text-zinc-600 mb-12 flex items-center gap-4">
                Engineering Breakdowns <span class="h-px flex-1 bg-zinc-900"></span>
            </h2>
            
            <ul class="space-y-8">
                {deepDives.map(dive => (
                    <li class="flex items-start gap-4 group">
                        <span class="text-blue-500/50 mt-1.5 min-w-[12px]">λ</span>
                        <div class="flex-1">
                            <a href={`/deepDives/${dive.slug}`} class="text-zinc-200 hover:text-blue-400 border-b border-zinc-900 hover:border-blue-900 transition-all text-xl leading-tight block pb-1">
                                {dive.data.title}
                            </a>
                            <div class="flex flex-wrap gap-3 text-[10px] font-mono text-zinc-600 mt-2 grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all">
                                <span>{new Date(dive.data.date).toLocaleDateString(undefined, { year: 'numeric', month: 'short' })}</span>
                                <span>/</span>
                                {dive.data.stack?.map(tech => (
                                    <span class="text-zinc-500">{tech}</span>
                                ))}
                            </div>
                        </div>
                    </li>
                ))}
            </ul>
        </div>

        <div class="scholarly-hr"></div>

        <!-- Series Index -->
        <div class="grid grid-cols-1 gap-14">
            
            {featuredSeries.map(seriesName => (
                <section>
                    <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-500 mb-6 flex items-center gap-4">
                        {seriesName} <span class="h-px flex-1 bg-zinc-900"></span>
                    </h2>
                    <ul class="space-y-6">
                        {entriesBySeries[seriesName].map(note => (
                            <li class="flex items-start gap-4 group">
                                <span class="text-blue-500/50 mt-1.5 min-w-[12px]">⊕</span>
                                <div class="flex-1">
                                    <a href={`/freeNotes/${note.slug}`} class="text-zinc-200 hover:text-blue-400 border-b border-zinc-900 hover:border-blue-900 transition-all text-xl leading-tight block pb-1">
                                        {note.data.title}
                                    </a>
                                    <div class="flex gap-3 text-xs font-mono text-zinc-600 mt-1.5 grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all">
                                        <span>{new Date(note.data.date).toLocaleDateString(undefined, { year: 'numeric', month: 'short' })}</span>
                                    </div>
                                </div>
                            </li>
                        ))}
                    </ul>
                </section>
            ))}

            {/* Optionally show Uncollected notes under a clean title */}
            {entriesBySeries['Uncollected'] && entriesBySeries['Uncollected'].length > 0 && (
                <section>
                    <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-500 mb-6 flex items-center gap-4">
                        Miscellaneous / Uncollected <span class="h-px flex-1 bg-zinc-900"></span>
                    </h2>
                    <ul class="space-y-6">
                        {entriesBySeries['Uncollected'].map(note => (
                            <li class="flex items-start gap-4 group">
                                <span class="text-zinc-800 mt-1.5 min-w-[12px]">⬽</span>
                                <div class="flex-1">
                                    <a href={`/freeNotes/${note.slug}`} class="text-zinc-200 hover:text-blue-400 border-b border-zinc-900 hover:border-blue-900 transition-all text-xl leading-tight block pb-1">
                                        {note.data.title}
                                    </a>
                                </div>
                            </li>
                        ))}
                    </ul>
                </section>
            )}

        </div>

        <div class="scholarly-hr mt-20"></div>
        
        <footer class="text-zinc-600 text-sm italic py-10 max-w-lg">
            "I'm not trying to predict the future of technology. I'm trying to help shape the kind of builders and systems that should exist in it."
        </footer>
    </main>
  </div>
</Layout>
