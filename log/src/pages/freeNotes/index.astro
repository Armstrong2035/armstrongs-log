---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ScholarlyHeader from '../../components/ScholarlyHeader.astro';

const allFreeNotes = await getCollection('freeNotes');
const sortedNotes = allFreeNotes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const getSeriesName = (note) => {
    if (!note.data.series) return null;
    return typeof note.data.series === 'string' ? note.data.series : note.data.series.name;
};
---

<Layout title="Free Notes | Armstrong's Log">
  <div class="min-h-screen bg-zinc-950 text-zinc-300 pb-20">
    <ScholarlyHeader />
    <main class="max-w-2xl mx-auto px-6">
        <header class="mb-16">
            <h1 class="text-4xl font-bold text-white mb-4 tracking-tight">Free Notes</h1>
            <p class="text-zinc-500 text-lg">Explorations in technology, philosophy, and the gaps in between.</p>
        </header>

        <ul class="space-y-12">
            {sortedNotes.map(note => (
                <li class="flex items-start gap-5 group">
                    <span class="text-zinc-800 mt-2 min-w-[12px]">⊕</span>
                    <div class="flex-1">
                        <a href={`/freeNotes/${note.slug}`} class="text-zinc-300 hover:text-blue-400 border-b border-zinc-900 transition-all text-xl leading-tight block pb-1">
                            {note.data.title}
                        </a>
                        <div class="flex gap-3 text-xs font-mono text-zinc-600 mt-2">
                            <span>{new Date(note.data.date).toLocaleDateString(undefined, { year: 'numeric', month: 'short' })}</span>
                            {getSeriesName(note) && (
                                <a href={`/series/${getSeriesName(note).toLowerCase().replace(/\s+/g, '-')}`} class="uppercase tracking-tighter text-zinc-700 hover:text-white transition-colors">/ {getSeriesName(note)}</a>
                            )}
                        </div>
                        {note.data.description && (
                            <p class="text-zinc-500 text-sm mt-3 leading-relaxed italic font-serif">
                                {note.data.description}
                            </p>
                        )}
                    </div>
                </li>
            ))}
        </ul>

        <div class="scholarly-hr mt-24"></div>
        <a href="/archives" class="text-zinc-600 hover:text-white transition-colors text-sm">← Back to Master Index</a>
    </main>
  </div>
</Layout>
